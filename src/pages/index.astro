---
/**
 * Accueil — promesse claire + CTA appel immédiat + accès rapide aux
 * prestations (CLAUDE.md §5). JSON-LD ProfessionalService (SEO local).
 */
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CallButton from '../components/CallButton.astro';
import CtaFinal from '../components/CtaFinal.astro';
import { site } from '../site';
import heroBureau from '../assets/hero-bureau.png';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: site.nom,
  description:
    "Écrivain public à Saint-Vallier-de-Thiey : courriers administratifs, litiges, récits de vie, discours, aide aux démarches en ligne.",
  url: Astro.site?.href,
  telephone: site.tel.href.replace('tel:', ''),
  image: new URL('/logo.svg', Astro.site).href,
  address: {
    '@type': 'PostalAddress',
    // Décision client : pas d'adresse exacte publiée — ville uniquement
    addressLocality: site.adresse.ville,
    postalCode: site.adresse.codePostal,
    addressCountry: 'FR',
  },
  areaServed: site.communes.map((c) => ({ '@type': 'City', name: c })),
  priceRange: 'Sur devis',
};
---

<BaseLayout
  title="Écrivain public à Saint-Vallier-de-Thiey — Prête moi ta plume"
  description="Écrivain public à Saint-Vallier-de-Thiey (pays de Grasse). Courriers administratifs, litiges, récits de vie, aide aux démarches. Appelez-nous."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script is:inline slot="head">
    // Première visite → entrée par la page sommaire (/bienvenue).
    // Exécuté dans le <head> (aucun flash de contenu). Les robots
    // d'indexation sont exclus pour préserver le référencement de l'accueil.
    try {
      var bot = /bot|crawl|spider|slurp|lighthouse|pagespeed/i.test(navigator.userAgent);
      if (!bot && !localStorage.getItem('pmtp-deja-venu')) {
        localStorage.setItem('pmtp-deja-venu', '1');
        location.replace('/bienvenue');
      }
    } catch (e) {
      /* navigation privée : pas de redirection */
    }
  </script>

  <!-- HERO — feuille blanche, trait de plume sous le mot clé -->
  <section class="section hero">
    <div class="container hero__grid">
      <div>
        <p class="eyebrow">Écrivaine publique à <span class="nowrap">Saint-Vallier-de-Thiey</span></p>
        <h1 class="hero__title">
          Vous n'êtes plus <span class="hero__stroke">seul<svg viewBox="0 0 120 14" aria-hidden="true" focusable="false" preserveAspectRatio="none"><path d="M4 10.5 C 30 4.5, 62 3.5, 88 6 C 100 7.2, 110 8.5, 116 9.8" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" /></svg></span> face à vos papiers.
        </h1>
        <p class="lead hero__lead">
          Un courrier administratif à écrire, un litige à régler, une histoire à
          raconter&nbsp;? Nous mettons les mots justes sur ce qui compte pour vous,
          en toute confidentialité.
        </p>
        <div class="hero__actions">
          <CallButton variant="solid" />
          <a class="btn btn--outline" href="/le-metier">Découvrir le métier</a>
        </div>
        <p class="hero__note">Le plus simple pour commencer&nbsp;: un appel. Sans engagement.</p>
      </div>
      <div class="hero__media">
        <Image
          src={heroBureau}
          alt="Bureau d'écrivaine publique à Saint-Vallier-de-Thiey : porte-plume sur une feuille vierge, encrier et lunettes près de la fenêtre"
          widths={[480, 760, 1086, 1448]}
          sizes="(min-width: 62rem) 44vw, calc(100vw - 3rem)"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- PRESTATIONS (aperçu) — feuilles blanches sur bureau sauge -->
  <section class="section on-sage">
    <div class="container">
      <h2>Ce que nous écrivons pour vous</h2>
      <div class="cards">
        <article class="card stack">
          <h3>Courriers administratifs</h3>
          <p>Une lettre à la mairie, à la caisse de retraite, à l'assurance&nbsp;? Nous la rédigeons avec vous, mot à mot.</p>
        </article>
        <article class="card stack">
          <h3>Récits de vie</h3>
          <p>Votre histoire mérite d'être écrite. Pour vous, pour vos enfants, pour ceux qui viendront après.</p>
        </article>
        <article class="card stack">
          <h3>Démarches en ligne</h3>
          <p>Impôts, CAF, Ameli… Nous faisons les démarches à vos côtés, patiemment, sur nos écrans ou les vôtres.</p>
        </article>
      </div>
      <div class="cards-more">
        <a class="btn btn--outline" href="/prestations">Voir toutes les prestations</a>
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA SE PASSE — version courte, renvoie vers Le métier -->
  <section class="section">
    <div class="container">
      <h2>Simple comme un coup de fil</h2>
      <ol class="mini-steps">
        <li>
          <strong>Vous appelez.</strong> Vous expliquez votre situation, avec
          vos mots. C'est gratuit.
        </li>
        <li>
          <strong>Nous nous rencontrons.</strong> Au cabinet, chez vous ou à
          distance — comme il vous convient.
        </li>
        <li>
          <strong>Vous repartez avec le bon texte.</strong> Relu ensemble,
          validé par vous, prêt à l'emploi.
        </li>
      </ol>
      <p class="mini-steps__more">
        <a href="/le-metier">Voir comment nous travaillons en détail</a>
      </p>
    </div>
  </section>

  <!-- RÉASSURANCE — le bloc encre, un seul, avant le CTA final -->
  <section class="section on-ink">
    <div class="container prose">
      <h2>Discrétion totale, c'est promis</h2>
      <p>
        Ce que vous nous confiez ne sort pas d'ici. Pas d'exemple montré, pas
        de document réutilisé, pas de question indiscrète restée sans réponse.
        Votre histoire vous appartient — nous ne faisons que l'écrire.
      </p>
    </div>
  </section>

  <CtaFinal title="On s'appelle ?">
    Racontez-nous ce que vous avez à écrire. En quelques minutes au téléphone,
    vous saurez si nous pouvons vous aider, comment, et pour quel budget.
  </CtaFinal>
</BaseLayout>

<style>
  /* --- Hero --- */
  .hero .eyebrow { margin-bottom: var(--space-lg); }

  .hero__grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
  }
  @media (min-width: 62rem) {
    .hero__grid { grid-template-columns: 1.1fr 0.9fr; gap: var(--space-2xl); }
  }

  /* La photo, posée comme une feuille : trait d'encre fin, coin discret */
  .hero__media :global(img) {
    border: 2px solid var(--c-sage);
    border-radius: var(--radius-card);
    width: 100%;
    height: auto;
  }

  .hero__title { max-width: 14ch; }

  /* Le trait de plume — la signature de la page */
  .hero__stroke {
    position: relative;
    display: inline-block;
  }
  .hero__stroke svg {
    position: absolute;
    left: -0.06em;
    right: -0.06em;
    bottom: -0.14em;
    width: calc(100% + 0.12em);
    height: 0.18em;
  }

  .hero__lead {
    margin-top: var(--space-lg);
    max-width: 46ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .hero__note {
    margin-top: var(--space-md);
    font-size: var(--fs-small);
  }

  @media (min-width: 48rem) {
    .hero { padding-block: var(--space-3xl); }
  }

  /* --- Cartes prestations --- */
  .cards {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: 1fr;
    margin-top: var(--space-xl);
  }
  @media (min-width: 40rem) {
    .cards { grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); }
  }

  .cards-more { margin-top: var(--space-xl); }

  /* --- Mini-étapes --- */
  .mini-steps {
    margin-top: var(--space-lg);
    padding-left: 1.5rem;
    display: grid;
    gap: var(--space-md);
  }
  .mini-steps li { max-width: var(--measure); padding-left: var(--space-xs); }
  .mini-steps__more { margin-top: var(--space-lg); }
</style>
