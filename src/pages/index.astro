---
/**
 * Accueil — la porte d'entrée du site : bandeau de marque (logo de la carte
 * de visite + tagline) et sommaire des sections, comme la table des matières
 * d'un livre. Page indexée (référencement), avec pied de page (NAP, EI,
 * mentions légales).
 *
 * Page volontairement autonome (pas de header collant) pour préserver l'effet
 * « couverture » ; la navigation se fait par le grand sommaire + le pied de page.
 */
import { Image } from 'astro:assets';
import '../styles/global.css';
import CallButton from '../components/CallButton.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site';
import heroBureau from '../assets/hero-bureau.png';

// Sommaire : les sections de contenu (pas d'« Accueil » — on y est déjà).
const nav = [
  { href: '/le-metier', label: 'Le métier', detail: "Ce qu'est un écrivain public" },
  { href: '/le-cabinet', label: 'Le cabinet', detail: 'Le lieu, la zone d’intervention' },
  { href: '/prestations', label: 'Prestations', detail: 'Courriers, récits, démarches…' },
  { href: '/realisations', label: 'Réalisations', detail: 'Ce que les clients en disent' },
  { href: '/questions-frequentes', label: 'Questions fréquentes', detail: 'Prix, délais, confidentialité' },
  { href: '/contact', label: 'Contact', detail: 'Téléphone, formulaire' },
];

const canonical = new URL('/', Astro.site).href;
const ogImage = new URL('/og-default.jpg', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: site.nom,
  description:
    "Écrivain public et biographe à Saint-Vallier-de-Thiey : courriers administratifs, litiges, récits de vie, discours, aide aux démarches en ligne.",
  url: canonical,
  telephone: site.tel.href.replace('tel:', ''),
  image: new URL('/logo.svg', Astro.site).href,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.adresse.ville,
    postalCode: site.adresse.codePostal,
    addressCountry: 'FR',
  },
  areaServed: site.communes.map((c) => ({ '@type': 'City', name: c })),
  priceRange: 'Sur devis',
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="only light" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <title>Écrivain public à Saint-Vallier-de-Thiey — Prête moi ta plume</title>
    <meta
      name="description"
      content="Écrivain public et biographe à Saint-Vallier-de-Thiey (pays de Grasse) : courriers administratifs, litiges, récits de vie, démarches. Appelez-moi."
    />
    <link rel="canonical" href={canonical} />

    <link rel="preload" href="/fonts/atkinson-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-variable-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Open Graph / partage -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.nom} />
    <meta property="og:title" content="Écrivain public à Saint-Vallier-de-Thiey — Prête moi ta plume" />
    <meta property="og:description" content="Écrivaine publique et biographe : courriers, récits de vie, démarches. Appelez-moi." />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="entree">
    <main>
      <div class="container entree__brand">
        <header class="entree__tete">
          <div class="brand">
            <img src="/logo-plume.svg" alt="" class="brand__feather" width="36" height="114" />
            <h1 class="brand__wordmark">
              <img src="/logo-wordmark.svg" alt="Prête-moi ta plume" width="188" height="41" />
            </h1>
          </div>
          <p class="brand__name">Elsa Marcoux, écrivaine publique &amp; biographe</p>
          <p class="brand__tagline">
            <span class="brand__tagline-1">sur toute la Côte d'Azur…</span>
            <span class="brand__tagline-2">et partout où il y a des histoires à écrire.</span>
          </p>
        </header>
      </div>

      <!-- HERO — texte à gauche, photo fondue à droite (sans cadre) -->
      <section class="hero">
        <div class="hero__text">
          <h2 class="hero__title">Chaque histoire mérite les mots justes.</h2>
          <p class="hero__lead">
            Écrivaine publique et biographe, je mets ma plume au service de vos
            émotions, de vos souvenirs et de vos projets.
          </p>
          <p class="hero__signature">
            Parce que chaque vie mérite d'être racontée avec justesse et sensibilité.
          </p>
          <div class="hero__actions">
            <CallButton variant="solid" />
            <a class="btn btn--outline" href="/contact">Échangeons sur votre projet</a>
          </div>
        </div>
        <div class="hero__media">
          <Image
            src={heroBureau}
            alt="Bureau d'écrivaine publique : porte-plume sur une feuille vierge, encrier et lunettes près de la fenêtre"
            widths={[480, 760, 1086, 1448]}
            sizes="(min-width: 62rem) 50vw, 100vw"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </section>

      <div class="container entree__sommaire">
      <p class="entree__prompt">Par où souhaitez-vous commencer&nbsp;?</p>

      <nav aria-label="Sommaire du site">
        <ul class="entree__menu">
          {nav.map((item) => (
            <li>
              <a href={item.href}>
                <span class="entree__label">{item.label}</span>
                <span class="entree__detail">{item.detail}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

        <div class="entree__appel">
          <p>Le plus simple reste un appel&nbsp;:</p>
          <CallButton variant="solid" block={true} />
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .entree { background: var(--c-paper); }

  .entree__brand { max-width: 44rem; padding-block: var(--space-3xl) 0; }
  .entree__sommaire {
    display: flex;
    flex-direction: column;
    max-width: 44rem;
    padding-bottom: var(--space-2xl);
  }

  /* ----------------------------------------------------------------------
     HERO — texte + photo qui se fond dans le papier (aucun cadre)
     ------------------------------------------------------------------- */
  .hero {
    display: grid;
    gap: var(--space-lg);
    align-items: center;
    max-width: 66rem;
    margin: var(--space-2xl) auto;
  }

  .hero__text {
    max-width: 44rem;
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }

  .hero__title {
    font-size: var(--fs-h2);
    font-weight: 540;
    max-width: 16ch;
  }
  .hero__lead {
    margin-top: var(--space-md);
    font-size: var(--fs-lead);
    max-width: 44ch;
  }
  .hero__signature {
    margin-top: var(--space-md);
    font-family: var(--font-title);
    font-style: italic;
    max-width: 44ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  /* Le fondu : l'image s'efface progressivement dans le fond papier.
     Mobile : fondu par le haut (l'image est sous le texte). */
  .hero__media :global(img) {
    width: 100%;
    height: auto;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 32%);
    mask-image: linear-gradient(to bottom, transparent 0%, #000 32%);
  }

  @media (min-width: 62rem) {
    .hero {
      /* Pleine largeur : l'image file jusqu'au bord droit de l'écran,
         il n'y a donc aucun bord net — elle se fond dans le papier. */
      max-width: none;
      /* Colonne 1 = gouttière calée sur la grille du sommaire (44rem centré) ;
         le column-gap fournit le padding, d'où l'alignement exact du texte. */
      grid-template-columns:
        calc((100% - 44rem) / 2)
        minmax(0, 26rem)
        1fr;
      column-gap: var(--space-xl);
      margin-block: var(--space-3xl);
    }
    .hero__text { grid-column: 2; max-width: none; margin: 0; padding-inline: 0; }
    .hero__media { grid-column: 3; }
    /* Desktop : fondu par la gauche (vers le texte) + haut/bas adoucis,
       pour qu'aucun bord ne soit net. */
    .hero__media :global(img) {
      -webkit-mask-image:
        linear-gradient(to right, transparent 0%, #000 45%),
        linear-gradient(to bottom, transparent 0%, #000 15%, #000 85%, transparent 100%);
      mask-image:
        linear-gradient(to right, transparent 0%, #000 45%),
        linear-gradient(to bottom, transparent 0%, #000 15%, #000 85%, transparent 100%);
      -webkit-mask-composite: source-in;
      mask-composite: intersect;
    }
  }

  .entree__tete { text-align: center; color: var(--c-ink); }

  /* Le logo de la carte de visite : plume + « Prête-moi ta plume » manuscrit */
  .brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
  }
  .brand__feather { height: 132px; width: auto; }
  .brand__wordmark { margin: 0; line-height: 0; }
  .brand__wordmark img { height: 92px; width: auto; }

  .brand__name {
    margin: var(--space-lg) auto 0;
    font-family: var(--font-title);
    font-size: var(--fs-h3);
    font-weight: 520;
  }

  /* Tagline : décalée, « et partout… » sous la fin de « Azur » */
  .brand__tagline {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-title);
    font-style: italic;
    font-size: var(--fs-lead);
    text-align: left;
  }
  .brand__tagline-1 { display: block; }
  .brand__tagline-2 {
    display: block;
    margin-top: var(--space-2xs);
    padding-left: 4em;             /* décale vers la fin de « Azur » */
    font-size: var(--fs-body);
  }

  /* Invite au-dessus du sommaire */
  .entree__prompt {
    text-align: center;
    margin-top: var(--space-2xl);
    font-size: var(--fs-lead);
  }

  @media (max-width: 30rem) {
    .brand { gap: var(--space-sm); }
    .brand__feather { height: 92px; }
    .brand__wordmark img { height: 62px; }
    .brand__tagline-2 { padding-left: 2em; }
  }

  /* Le sommaire — grandes entrées, filets fins, comme une table des matières */
  .entree__menu {
    list-style: none;
    padding: 0;
    margin-top: var(--space-xl);
    border-top: var(--hairline) solid var(--c-ink);
  }
  .entree__menu a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    min-height: var(--tap-min);
    padding: var(--space-md) var(--space-xs);
    text-decoration: none;
    border-bottom: var(--hairline) solid var(--c-ink);
  }
  .entree__menu a:hover { background: var(--c-sage); }

  .entree__label {
    font-family: var(--font-title);
    font-size: var(--fs-h3);
    font-weight: 540;
    line-height: var(--lh-title);
  }
  .entree__detail { font-size: var(--fs-small); }

  .entree__appel {
    margin-top: var(--space-xl);
    text-align: center;
  }
  .entree__appel p { margin-bottom: var(--space-sm); margin-inline: auto; }

  @media (max-width: 40rem) {
    .entree__detail { display: none; } /* mobile : entrées épurées, libellés seuls */
  }
</style>
