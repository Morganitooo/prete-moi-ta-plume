---
/**
 * Prestations — que fait-on concrètement. Un service = un bloc.
 * Tarifs : tout sur devis (décision client) — aucun prix affiché.
 * NOTE : liste à faire valider par la cliente ; retirer/ajouter des blocs
 * au besoin. [À COMPLÉTER]
 */
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaFinal from '../components/CtaFinal.astro';
import prestationsBandeau from '../assets/prestations-bandeau.png';
import { prestations } from '../prestations';

---

<BaseLayout
  title="Prestations d'écrivain public — Prête moi ta plume"
  description="Courriers administratifs, litiges, récits de vie, discours, démarches en ligne : mes prestations d'écrivain public près de Grasse. Devis gratuit."
>
  <PageHeader eyebrow="Prestations" title="Ce que j'écris pour vous">
    <p>
      Chaque situation est différente&nbsp;: tout travail commence par un
      échange et un devis, gratuits et sans engagement. Le prix est annoncé
      avant de commencer — jamais de surprise.
    </p>
  </PageHeader>

  <!-- Bandeau d'ambiance — au-dessus de la ligne de flottaison → eager -->
  <div class="container prestations-bandeau">
    <Image
      src={prestationsBandeau}
      alt="Enveloppes, stylo plume et papier à lettres soigneusement disposés sur un lin vert sauge"
      widths={[720, 1200, 1916]}
      sizes="(min-width: 70rem) 66rem, calc(100vw - 3rem)"
      loading="eager"
    />
  </div>

  <!-- Un service = un bloc -->
  <section class="section prestations-liste">
    <div class="container">
      <div class="prestas">
        {prestations.map((p) => (
          <article class="presta">
            <div class="presta__titre">
              <span class="presta__icone" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d={p.icone} stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <h2>{p.titre}</h2>
            </div>
            <p>{p.texte}</p>
            <p class="presta__exemples"><strong>Par exemple&nbsp;:</strong> {p.exemples}</p>
            <hr class="rule-sage presta__rule" />
          </article>
        ))}
      </div>
      <p class="prestations-note prose">
        Vous ne trouvez pas votre situation dans cette liste&nbsp;?
        Appelez quand même&nbsp;: si des mots sont à écrire, je peux
        sans doute vous aider — et sinon, je vous dirai vers qui vous tourner.
      </p>
    </div>
  </section>

  <CtaFinal title="Demandez votre devis gratuit">
    Décrivez-moi ce dont vous avez besoin&nbsp;: je vous réponds
    simplement, avec un prix clair et sans engagement.
  </CtaFinal>
</BaseLayout>

<style>
  .prestations-bandeau { margin-bottom: var(--space-2xl); }
  .prestations-bandeau :global(img) {
    border: 2px solid var(--c-sage);
    border-radius: var(--radius-card);
    width: 100%;
    height: auto;
  }

  .prestations-liste { padding-top: 0; }

  .prestas {
    display: grid;
    gap: var(--space-xl);
  }

  .presta__titre {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }
  .presta__icone {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: var(--c-ink);
    background: var(--c-sage);
    border-radius: 50%;
  }
  .presta__icone svg { width: 26px; height: 26px; }

  .presta h2 { font-size: var(--fs-h3); }
  .presta p { margin-top: var(--space-sm); }
  .presta__exemples { font-size: var(--fs-small); }
  .presta__rule { margin-top: var(--space-xl); }
  .presta:last-child .presta__rule { display: none; }

  .prestations-note { margin-top: var(--space-2xl); }
</style>
