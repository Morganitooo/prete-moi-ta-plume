---
/**
 * Prestations — que fait-on concrètement. Un service = un bloc.
 * Tarifs : tout sur devis (décision client) — aucun prix affiché.
 * NOTE : liste à faire valider par la cliente ; retirer/ajouter des blocs
 * au besoin. [À COMPLÉTER]
 */
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaFinal from '../components/CtaFinal.astro';
import prestationsBandeau from '../assets/prestations-bandeau.png';

// Icônes au trait (24×24, stroke encre) — toujours accompagnées du titre
// (CLAUDE.md §4 : jamais d'icône seule).
const icones: Record<string, string> = {
  enveloppe: 'M3 6.5h18v11.5H3z M3 7.5l9 6 9-6',
  balance: 'M12 4.5v15 M9 19.5h6 M5 7.5h14 M5 7.5l-2.6 5.4a2.9 2.9 0 0 0 5.2 0L5 7.5 M19 7.5l-2.6 5.4a2.9 2.9 0 0 0 5.2 0L19 7.5',
  livre: 'M12 6.5C10 5 7.2 4.4 4 4.4v13.8c3.2 0 6 .6 8 2.1 2-1.5 4.8-2.1 8-2.1V4.4c-3.2 0-6 .6-8 2.1v13.8',
  discours: 'M4.5 5h15a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1h-9l-5.5 4v-4h-.5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z M8 9.5h8 M8 12.5h5',
  ecran: 'M3.5 5h17v11h-17z M9.5 20h5 M12 16v4 M7 12l3-3 2 2 4-4',
  plumecheck: 'M4 20l1.8-5.4L15 5.4l3.6 3.6-9.2 9.2L4 20z M13.2 7.2l3.6 3.6',
};

const prestations = [
  {
    titre: 'Courriers administratifs',
    icone: icones.enveloppe,
    texte:
      "Mairie, caisse de retraite, préfecture, assurance, bailleur… Nous rédigeons vos lettres officielles, claires et complètes, pour que votre demande aboutisse.",
    exemples: 'Demandes, attestations, recours gracieux, résiliations.',
  },
  {
    titre: 'Litiges et réclamations',
    icone: icones.balance,
    texte:
      "Un différend avec un commerçant, un artisan, un organisme ? Nous posons les faits par écrit, fermement et poliment, pour défendre votre position.",
    exemples: 'Réclamations, contestations, lettres de relance.',
  },
  {
    titre: 'Récits de vie et biographies',
    icone: icones.livre,
    texte:
      "Votre histoire, celle d'un parent, la mémoire d'une famille. Nous la recueillons au fil d'entretiens, puis nous l'écrivons pour qu'elle se transmette.",
    exemples: 'Mémoires, histoire familiale, livre souvenir.',
  },
  {
    titre: 'Discours et textes personnels',
    icone: icones.discours,
    texte:
      "Mariage, anniversaire, départ en retraite, hommage à un proche disparu. Les mots justes pour les grands moments, ceux qu'on ne veut pas rater.",
    exemples: 'Discours, hommages, cartes et lettres personnelles.',
  },
  {
    titre: 'Aide aux démarches en ligne',
    icone: icones.ecran,
    texte:
      "Impôts, CAF, Ameli, carte grise… Les sites administratifs ne sont pas simples. Nous faisons les démarches avec vous, patiemment, jusqu'au bout.",
    exemples: 'Comptes en ligne, formulaires, suivi de dossiers.',
  },
  {
    titre: 'Relecture et mise au propre',
    icone: icones.plumecheck,
    texte:
      "Vous avez déjà écrit ? Nous relisons, corrigeons et mettons en forme votre texte, en respectant votre voix.",
    exemples: 'Correction, reformulation, mise en page.',
  },
];
---

<BaseLayout
  title="Prestations d'écrivain public — Prête moi ta plume"
  description="Courriers administratifs, litiges, récits de vie, discours, démarches en ligne : nos prestations d'écrivain public près de Grasse. Devis gratuit."
>
  <PageHeader eyebrow="Prestations" title="Ce que nous écrivons pour vous">
    <p>
      Chaque situation est différente&nbsp;: tout travail commence par un
      échange et un devis, gratuits et sans engagement. Le prix est annoncé
      avant de commencer — jamais de surprise.
    </p>
  </PageHeader>

  <!-- Bandeau d'ambiance — au-dessus de la ligne de flottaison → eager -->
  <div class="container prestations-bandeau">
    <Image
      src={prestationsBandeau}
      alt="Enveloppes, stylo plume et papier à lettres soigneusement disposés sur un lin vert sauge"
      widths={[720, 1200, 1916]}
      sizes="(min-width: 70rem) 66rem, calc(100vw - 3rem)"
      loading="eager"
    />
  </div>

  <!-- Un service = un bloc -->
  <section class="section prestations-liste">
    <div class="container">
      <div class="prestas">
        {prestations.map((p) => (
          <article class="presta">
            <div class="presta__titre">
              <span class="presta__icone" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d={p.icone} stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <h2>{p.titre}</h2>
            </div>
            <p>{p.texte}</p>
            <p class="presta__exemples"><strong>Par exemple&nbsp;:</strong> {p.exemples}</p>
            <hr class="rule-sage presta__rule" />
          </article>
        ))}
      </div>
      <p class="prestations-note prose">
        Vous ne trouvez pas votre situation dans cette liste&nbsp;?
        Appelez quand même&nbsp;: si des mots sont à écrire, nous pouvons
        sans doute vous aider — et sinon, nous vous dirons vers qui vous tourner.
      </p>
    </div>
  </section>

  <CtaFinal title="Demandez votre devis gratuit">
    Décrivez-nous ce dont vous avez besoin&nbsp;: nous vous répondons
    simplement, avec un prix clair et sans engagement.
  </CtaFinal>
</BaseLayout>

<style>
  .prestations-bandeau { margin-bottom: var(--space-2xl); }
  .prestations-bandeau :global(img) {
    border: 2px solid var(--c-sage);
    border-radius: var(--radius-card);
    width: 100%;
    height: auto;
  }

  .prestations-liste { padding-top: 0; }

  .prestas {
    display: grid;
    gap: var(--space-xl);
  }

  .presta__titre {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }
  .presta__icone {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    color: var(--c-ink);
    background: var(--c-sage);
    border-radius: 50%;
  }
  .presta__icone svg { width: 26px; height: 26px; }

  .presta h2 { font-size: var(--fs-h3); }
  .presta p { margin-top: var(--space-sm); }
  .presta__exemples { font-size: var(--fs-small); }
  .presta__rule { margin-top: var(--space-xl); }
  .presta:last-child .presta__rule { display: none; }

  .prestations-note { margin-top: var(--space-2xl); }
</style>
