---
/**
 * Bienvenue — page d'entrée dédiée (première visite) : le sommaire du site,
 * comme la table des matières d'un livre. Logo, mot d'accueil, les 7
 * sections en grandes entrées, téléphone.
 *
 * Page volontairement autonome (pas de BaseLayout : ni header, ni footer,
 * ni barre d'appel) et noindex — les visiteurs y sont amenés par le script
 * de première visite de l'accueil ; les moteurs, eux, restent sur `/`.
 */
import '../styles/global.css';
import CallButton from '../components/CallButton.astro';
import { site } from '../site';

const nav = [
  { href: '/', label: 'Accueil', detail: 'La promesse, en deux mots' },
  { href: '/le-metier', label: 'Le métier', detail: "Ce qu'est un écrivain public" },
  { href: '/prestations', label: 'Prestations', detail: 'Courriers, récits, démarches…' },
  { href: '/le-cabinet', label: 'Le cabinet', detail: 'Le lieu, la zone d’intervention' },
  { href: '/realisations', label: 'Réalisations', detail: 'Ce que les clients en disent' },
  { href: '/questions-frequentes', label: 'Questions fréquentes', detail: 'Prix, délais, confidentialité' },
  { href: '/contact', label: 'Contact', detail: 'Téléphone, formulaire' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Bienvenue — Prête moi ta plume</title>
    <meta name="description" content="Bienvenue chez Prête moi ta plume, écrivaine publique à Saint-Vallier-de-Thiey. Choisissez par où commencer." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/fonts/atkinson-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-variable-latin.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // Quelqu'un qui arrive ici directement est considéré comme déjà venu :
      // pas de re-redirection depuis l'accueil ensuite.
      try { localStorage.setItem('pmtp-deja-venu', '1'); } catch {}
    </script>
  </head>

  <body class="entree">
    <main class="entree__main container">
      <header class="entree__tete">
        <img src="/logo.svg" width="216" height="50" alt={`${site.nom} — ${site.baseline}`} class="entree__logo" />
        <h1>Bienvenue</h1>
        <p class="eyebrow">Écrivaine publique à <span class="nowrap">Saint-Vallier-de-Thiey</span></p>
        <p class="entree__mot">Par où souhaitez-vous commencer&nbsp;?</p>
      </header>

      <nav aria-label="Sommaire du site">
        <ul class="entree__menu">
          {nav.map((item) => (
            <li>
              <a href={item.href}>
                <span class="entree__label">{item.label}</span>
                <span class="entree__detail">{item.detail}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="entree__appel">
        <p>Le plus simple reste un appel&nbsp;:</p>
        <CallButton variant="solid" block={true} />
      </div>
    </main>
  </body>
</html>

<style>
  .entree { background: var(--c-paper); }

  .entree__main {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 44rem;
    padding-block: var(--space-xl);
  }

  .entree__tete { text-align: center; }
  .entree__logo { margin-inline: auto; height: 46px; width: auto; margin-bottom: var(--space-xl); }
  .entree__tete h1 { font-weight: 540; }
  .entree__tete .eyebrow { margin-top: var(--space-xs); }
  .entree__mot { margin-top: var(--space-lg); }
  .entree__tete p { margin-inline: auto; }

  /* Le sommaire — grandes entrées, filets fins, comme une table des matières */
  .entree__menu {
    list-style: none;
    padding: 0;
    margin-top: var(--space-xl);
    border-top: var(--hairline) solid var(--c-ink);
  }
  .entree__menu a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    min-height: var(--tap-min);
    padding: var(--space-md) var(--space-xs);
    text-decoration: none;
    border-bottom: var(--hairline) solid var(--c-ink);
  }
  .entree__menu a:hover { background: var(--c-sage); }

  .entree__label {
    font-family: var(--font-title);
    font-size: var(--fs-h3);
    font-weight: 540;
    line-height: var(--lh-title);
  }
  .entree__detail { font-size: var(--fs-small); }

  .entree__appel {
    margin-top: var(--space-xl);
    text-align: center;
  }
  .entree__appel p { margin-bottom: var(--space-sm); margin-inline: auto; }

  @media (max-width: 40rem) {
    .entree__detail { display: none; } /* mobile : entrées épurées, libellés seuls */
  }
</style>
